# Environment Variables Configuration
# Copy this to .env and fill in your actual values
# IMPORTANT: .env is in .gitignore - Never commit this file!

# ============ REQUIRED FOR PRODUCTION (Render) ============
# MongoDB Atlas Connection String
# Get from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/avva_home_foods
SPRING_DATA_MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/avva_home_foods?retryWrites=true&w=majority

# Google OAuth 2.0 Client ID
# Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id-here

# ============ LOCAL DEVELOPMENT ============
# Local MongoDB (if not using Docker)
# SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/avvahomefoods

# ============ OPTIONAL ============
# Server port (default: 8080)
# SERVER_PORT=8080

# Application environment (dev, test, prod)
# SPRING_PROFILES_ACTIVE=dev
